{
  "name": "TypeScript Dev Container",

  "build": {
    "dockerfile": "Dockerfile"
  },

  "workspaceFolder": "/workspace",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next"
      ]
    }
  },

  "postCreateCommand": "npm install",

  "remoteUser": "node"
}